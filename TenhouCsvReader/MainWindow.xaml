<Window x:Class="TenhouCsvReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tenhou CSV Reader (Read-Only)"
        Height="860"
        Width="1500"
        MinHeight="640"
        MinWidth="980"
        AllowDrop="True"
        SizeChanged="Window_SizeChanged"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
    <DockPanel LastChildFill="True" Background="#F3F5F7">
        <Border DockPanel.Dock="Top"
                Padding="12"
                Background="White"
                BorderThickness="0,0,0,1"
                BorderBrush="#D0D7DE">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="OpenCsvButton"
                            Content="Open CSV"
                            Padding="14,6"
                            Margin="0,0,12,0"
                            Click="OpenCsvButton_Click" />
                    <TextBlock Text="Page Size:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox x:Name="PageSizeComboBox"
                              Width="90"
                              SelectedIndex="2"
                              SelectionChanged="PageSizeComboBox_SelectionChanged">
                        <ComboBoxItem Content="200" />
                        <ComboBoxItem Content="500" />
                        <ComboBoxItem Content="1000" />
                        <ComboBoxItem Content="2000" />
                    </ComboBox>
                    <CheckBox x:Name="BackgroundIndexCheckBox"
                              Content="Background full index"
                              IsChecked="True"
                              Margin="16,0,0,0"
                              VerticalAlignment="Center"
                              Checked="BackgroundIndexCheckBox_Changed"
                              Unchecked="BackgroundIndexCheckBox_Changed" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            Margin="0,10,0,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Filter:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBox x:Name="FilterTextBox"
                             Width="760"
                             VerticalContentAlignment="Center"
                             KeyDown="FilterTextBox_KeyDown" />
                    <Button x:Name="ApplyFilterButton"
                            Content="Apply"
                            Padding="12,4"
                            Margin="8,0,6,0"
                            Click="ApplyFilterButton_Click" />
                    <Button x:Name="ClearFilterButton"
                            Content="Clear"
                            Padding="12,4"
                            Click="ClearFilterButton_Click" />
                    <TextBlock Text="Example: prediction = 1, actual = 0, probability > 0.7"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#586069" />
                </StackPanel>

                <TextBlock x:Name="FilePathTextBlock"
                           Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,10,0,0"
                           Text="No file loaded."
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
                <TextBlock x:Name="IndexStatusTextBlock"
                           Grid.Row="2"
                           Grid.Column="1"
                           Margin="10,10,0,0"
                           VerticalAlignment="Center"
                           TextAlignment="Right" />

                <StackPanel Grid.Row="3"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            Margin="0,10,0,0"
                            VerticalAlignment="Center">
                    <Button x:Name="PreviousPageButton"
                            Content="Previous"
                            Padding="12,4"
                            Margin="0,0,8,0"
                            IsEnabled="False"
                            Click="PreviousPageButton_Click" />
                    <Button x:Name="NextPageButton"
                            Content="Next"
                            Padding="12,4"
                            Margin="0,0,12,0"
                            IsEnabled="False"
                            Click="NextPageButton_Click" />
                    <TextBlock Text="Go to page:" VerticalAlignment="Center" />
                    <TextBox x:Name="GoToPageTextBox"
                             Width="90"
                             Margin="6,0,6,0"
                             VerticalContentAlignment="Center" />
                    <Button x:Name="GoPageButton"
                            Content="Go"
                            Padding="10,4"
                            Click="GoPageButton_Click" />
                    <TextBlock x:Name="PageInfoTextBlock"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="BrowserSplitterColumn" Width="0" />
                <ColumnDefinition x:Name="BrowserColumn" Width="0" MinWidth="0" />
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="CsvDataGrid"
                      Grid.Column="0"
                      IsReadOnly="True"
                      AutoGenerateColumns="True"
                      AutoGeneratingColumn="CsvDataGrid_AutoGeneratingColumn"
                      PreviewMouseRightButtonDown="CsvDataGrid_PreviewMouseRightButtonDown"
                      PreviewMouseLeftButtonDown="CsvDataGrid_PreviewMouseLeftButtonDown"
                      PreviewMouseDoubleClick="CsvDataGrid_PreviewMouseDoubleClick"
                      PreviewMouseMove="CsvDataGrid_PreviewMouseMove"
                      MouseLeave="CsvDataGrid_MouseLeave"
                      PreviewKeyDown="CsvDataGrid_PreviewKeyDown"
                      ColumnWidth="SizeToHeader"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      RowHeaderWidth="0"
                      GridLinesVisibility="Horizontal"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      ScrollViewer.CanContentScroll="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ClipboardCopyMode="IncludeHeader">
                <DataGrid.ContextMenu>
                    <ContextMenu Opened="CsvDataGridContextMenu_Opened">
                        <MenuItem x:Name="CopyCellMenuItem"
                                  Header="Copy Cell"
                                  Click="CopyCellMenuItem_Click" />
                        <MenuItem x:Name="CopyRowCsvMenuItem"
                                  Header="Copy Row As CSV"
                                  Click="CopyRowCsvMenuItem_Click" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
            </DataGrid>

            <GridSplitter x:Name="BrowserSplitter"
                          Grid.Column="1"
                          Width="6"
                          Background="#D8DEE4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          ShowsPreview="True"
                          DragCompleted="BrowserSplitter_DragCompleted"
                          Visibility="Collapsed" />

            <Border x:Name="BrowserPane"
                    Grid.Column="2"
                    Margin="8,0,0,0"
                    Background="White"
                    BorderBrush="#D0D7DE"
                    BorderThickness="1"
                    CornerRadius="4"
                    Visibility="Collapsed">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top"
                            Padding="8"
                            Background="#F6F8FA"
                            BorderBrush="#D0D7DE"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="BrowserBackButton"
                                    Content="←"
                                    Width="28"
                                    Height="26"
                                    Margin="0,0,4,0"
                                    Click="BrowserBackButton_Click" />
                            <Button x:Name="BrowserForwardButton"
                                    Content="→"
                                    Width="28"
                                    Height="26"
                                    Margin="0,0,4,0"
                                    Click="BrowserForwardButton_Click" />
                            <Button x:Name="BrowserRefreshButton"
                                    Content="⟳"
                                    Width="28"
                                    Height="26"
                                    Margin="0,0,8,0"
                                    Click="BrowserRefreshButton_Click" />
                            <TextBox x:Name="BrowserAddressTextBox"
                                     MinWidth="140"
                                     Width="300"
                                     VerticalContentAlignment="Center"
                                     Margin="0,0,8,0"
                                     KeyDown="BrowserAddressTextBox_KeyDown" />
                            <Button x:Name="BrowserOpenExternalButton"
                                    Content="Open External"
                                    Padding="10,4"
                                    Margin="0,0,6,0"
                                    Click="BrowserOpenExternalButton_Click" />
                            <Button x:Name="BrowserCloseButton"
                                    Content="Close"
                                    Padding="10,4"
                                    Click="BrowserCloseButton_Click" />
                        </StackPanel>
                    </Border>

                    <wv2:WebView2 x:Name="SideBrowser"
                                  SourceChanged="SideBrowser_SourceChanged"
                                  NavigationCompleted="SideBrowser_NavigationCompleted"
                                  CoreWebView2InitializationCompleted="SideBrowser_CoreWebView2InitializationCompleted" />
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
